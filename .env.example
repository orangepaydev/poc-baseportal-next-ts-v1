AUTH_SESSION_SECRET=local-dev-session-secret

# Local host development reaches the smtpdev container through the mapped port.
# If the app later runs inside the same Compose network, switch these to:
# EMAIL_SMTP_HOST=smtpdev
# EMAIL_SMTP_PORT=25
EMAIL_FROM_ADDRESS=no-reply@portal.local
EMAIL_FROM_NAME=Portal Local
EMAIL_SMTP_HOST=127.0.0.1
EMAIL_SMTP_PORT=2525
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_SMTP_TLS_REJECT_UNAUTHORIZED=

# Comma-separated connection names. The first one becomes the default unless
# DB_DEFAULT_CONNECTION overrides it.
DB_CONNECTION_NAMES=default,reporting
DB_DEFAULT_CONNECTION=default
# Default cap for db.query() when the SQL does not already include LIMIT.
# Hard maximum: 10000.
DB_QUERY_RESULT_LIMIT=1000

# Supported database types: mariadb, postgresql

# Default application database
DB_DEFAULT_TYPE=mariadb
DB_DEFAULT_HOST=127.0.0.1
DB_DEFAULT_PORT=3306
DB_DEFAULT_DATABASE=portaldb
DB_DEFAULT_USER=dbuser
DB_DEFAULT_PASSWORD=dbpass123
DB_DEFAULT_SSL=false
DB_DEFAULT_CONNECTION_LIMIT=10
DB_DEFAULT_IDLE_TIMEOUT_MS=30000
DB_DEFAULT_CONNECTION_TIMEOUT_MS=5000

# Optional secondary connection example
DB_REPORTING_TYPE=postgresql
DB_REPORTING_HOST=127.0.0.1
DB_REPORTING_PORT=5432
DB_REPORTING_DATABASE=portal_reporting
DB_REPORTING_USER=postgres
DB_REPORTING_PASSWORD=postgres
DB_REPORTING_SSL=false
DB_REPORTING_CONNECTION_LIMIT=10
DB_REPORTING_IDLE_TIMEOUT_MS=30000
DB_REPORTING_CONNECTION_TIMEOUT_MS=5000

# URL-based configuration is also supported. If you use a URL for a connection,
# the host/port/database/user/password fields for that same connection are not
# required.
# DB_DEFAULT_URL=mysql://dbuser:dbpass123@127.0.0.1:3306/portaldb
# DB_REPORTING_URL=postgresql://postgres:postgres@127.0.0.1:5432/portal_reporting